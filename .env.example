# Mirage Terminal — Environment Variables
# Copy this file to .env.local for local development

# At least one AI provider API key is required for AI chat fallthrough.
# Providers are tried in order: Gemini -> Groq -> OpenRouter

# Google Gemini API key (free tier available)
# Get one at: https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# Groq API key (free tier available)
# Get one at: https://console.groq.com/keys
# GROQ_API_KEY=

# OpenRouter API key (free tier available)
# Get one at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# Rate Limiting (in-memory by default; swap to Upstash Redis for Vercel production)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
